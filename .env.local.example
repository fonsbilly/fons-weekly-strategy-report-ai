# Copy this file to .env.local for local reference only.
# Real values are set in the Vercel dashboard (Project Settings -> Environment Variables),
# scoped to Production / Preview / Development as needed. Never commit real values.

# Supabase (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API key) - server-side only, never exposed to the client
ANTHROPIC_API_KEY=
